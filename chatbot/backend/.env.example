# Google Sheets Configuration
SHEETS_ID=your-google-sheets-id
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/credentials.json

# Server Configuration
HOST=0.0.0.0
PORT=8000

# gpt4free Configuration
GPT4FREE_PROVIDER=default
GPT4FREE_MODEL=gpt-3.5-turbo

# Session Configuration
SESSION_TIMEOUT=3600
MAX_HISTORY=50